# =============================================================================
# Werbenest Shop – Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` to git.
# =============================================================================

# ---- Vercel (nur lokal / CI – nicht ins Vercel-Dashboard pushen) ------------
# https://vercel.com/account/tokens — für `pnpm vercel:env-push`
VERCEL_TOKEN=

# ---- Supabase ---------------------------------------------------------------
# Dashboard: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # Public anon key – safe in browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # Server-only! Bypasses RLS. NEVER expose.

# Direct Postgres connection – used by scripts/migrate.ts, seed.ts, verify-rls.ts.
# Dashboard: Project Settings → Database → Connection string → "URI" (session pooler)
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Or direct: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ---- Site / Deployment ------------------------------------------------------
# Public base URL (used for email links, Stripe redirects, Supabase auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Stripe -----------------------------------------------------------------
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret – generated per-endpoint in Stripe dashboard / Stripe CLI
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- SMTP (Nodemailer) -----------------------------------------------------
# Works with Office 365, Google Workspace, Mailgun, SendGrid SMTP etc.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587                  # 587 = STARTTLS, 465 = SSL
SMTP_SECURE=false              # true for port 465, false for 587
SMTP_USER=no-reply@example.com
SMTP_PASS=your-app-password
SMTP_FROM="Werbenest <no-reply@example.com>"

# ---- SMTP Production (z. B. Resend) -----------------------------------------
# Wird von `pnpm vercel:env-push` als SMTP_HOST / SMTP_PORT / … nach Vercel gemappt
# (lokale Mailpit-Werte bleiben unangetastet).
SMTP_HOST_PROD=smtp.resend.com
SMTP_PORT_PROD=465
SMTP_SECURE_PROD=true
SMTP_USER_PROD=resend
SMTP_PASS_PROD=re_xxxxxxxx   # Resend API Key
SMTP_FROM_PROD="Werbenest <info@werbenest.de>"

# ---- Company / Invoicing ----------------------------------------------------
COMPANY_NAME=Werbenest GmbH
COMPANY_STREET=Musterstraße 1
COMPANY_ZIP=12345
COMPANY_CITY=Berlin
COMPANY_COUNTRY=Deutschland
COMPANY_VAT_ID=DE123456789
COMPANY_EMAIL=hallo@example.com
COMPANY_PHONE=+49 30 1234567
COMPANY_IBAN=DE00 0000 0000 0000 0000 00
COMPANY_BIC=XXXXDEXX
COMPANY_BANK=Beispielbank
# Standard-Mehrwertsteuer Deutschland
VAT_RATE_PERCENT=19

# =============================================================================
# Phase 2 / Phase 3 – not needed yet, keep empty in local dev
# =============================================================================

# ---- AI (Phase 2) -----------------------------------------------------------
ANTHROPIC_API_KEY=              # Claude Haiku 4.5 – Druckflächen-Detection
GEMINI_API_KEY=                 # Gemini 2.0 Flash Image – Moodboard-Generator (/moodboard)
GOOGLE_GENERATIVE_AI_API_KEY=   # Fallback für GEMINI_API_KEY (Gemini / Nano Banana 2)
REMOVE_BG_API_KEY=              # remove.bg – Logo Background Removal
VECTORIZER_API_ID=              # vectorizer.ai / recraft.ai
VECTORIZER_API_SECRET=

# ---- Supplier APIs (Phase 3) ------------------------------------------------
STRICKER_API_URL=
STRICKER_API_USER=
STRICKER_API_PASS=
PFCONCEPT_API_URL=
PFCONCEPT_API_TOKEN=
MAKITO_API_URL=
MAKITO_API_TOKEN=

# ---- Admin Bootstrap --------------------------------------------------------
# Email-Adresse, die beim ersten Seed automatisch als Owner markiert wird.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
